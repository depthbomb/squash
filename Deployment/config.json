{
    "applicationName": "Squash",
    "initialVersion": "3.0.0",
    "launchExecutable": "Squash.exe",
    "windowIconPath": "../Assets/icon.ico",
    "appearance": {
        "bannerBackgroundColor": "#f78c32"
    },
    "text": {
        "windowTitle": "{ApplicationName} Updater"
    },
    "installation": {
        "requireIntegrityVerification": true,
        "processName": "Squash",
        "keepLastVersions": 3,
        "extractionLayout": "auto",
        "allowFreshInstall": true,
		"compressFiles": true
    },
    "requiredRuntimes": [
        {
            "name": "Microsoft.WindowsDesktop.App",
            "version": "10.0.8",
            "type": "windowsdesktop-runtime"
        }
    ],
    "updateSource": {
        "type": "github",
        "repository": "depthbomb/squash",
        "assetNamePattern": "^app\\-package\\.zip$",
        "includePrerelease": false
    }
}
